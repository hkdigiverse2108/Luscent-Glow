# Production Environment Variables
# These are used when you run 'npm run build'

# The base URL for your API. 
# Using '/api' works perfectly if your frontend and backend are on the same domain
# or if you use a proxy (Vercel, Netlify, Nginx).
VITE_API_BASE_URL=/api

# Add your production LightWidget ID here
VITE_LIGHTWIDGET_ID=YOUR_PRODUCTION_ID
